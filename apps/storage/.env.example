# Storage Service Configuration
STORAGE_PORT=8081
GIN_MODE=debug

# Database Configuration (shared with backend)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=purrchat

# JWT Configuration (shared with backend for token validation)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Storage Provider: "minio" or "r2"
STORAGE_PROVIDER=minio

# MinIO Configuration (used when STORAGE_PROVIDER=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=purrchat
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# R2 Configuration (used when STORAGE_PROVIDER=r2)
# Fill in your Cloudflare R2 credentials below
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET=purrchat
R2_PUBLIC_URL=https://your-r2-public-url.com
R2_REGION=auto
