# Server Configuration
PORT=8080
GIN_MODE=debug

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=purrchat

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRATION=24h

# WebSocket Configuration
MAX_CONNECTIONS=20000
MAX_USER_DEVICE_CONNECTIONS=5

# Bot Engine (TS microservice, required for workflow execution)
BOT_ENGINE_URL=http://localhost:3001
# BOT_ENGINE_SHARED_SECRET=

# Secret Encryption (required for Bot secret store)
# Generate with: openssl rand -base64 32
PURRCHAT_MASTER_KEY=

# Bot Engine ↔ Backend shared secret (must match BOT_ENGINE_SHARED_SECRET on TS side)
BOT_ENGINE_SHARED_SECRET=
