# Server Configuration
PORT=8080
GIN_MODE=debug

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=purrchat

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
