{
  "name": "backend",
  "private": true,
  "version": "1.0.0",
  "description": "PurrChat Backend - Go API Server",
  "scripts": {
    "dev": "go run cmd/server/main.go",
    "build": "go build -o bin/server cmd/server/main.go",
    "test": "go test -v -race -coverprofile=coverage.out -covermode=atomic ./...",
    "test:coverage": "go test -v -race -coverprofile=coverage.out -covermode=atomic ./... && go tool cover -html=coverage.out -o coverage.html",
    "lint": "which golangci-lint && golangci-lint run --timeout=5m || go vet ./...",
    "type-check": "go vet ./...",
    "clean": "rm -rf bin coverage.out coverage.html logs/*.log",
    "migrate:up": "go run cmd/migrate/main.go up",
    "migrate:down": "go run cmd/migrate/main.go down"
  },
  "devDependencies": {},
  "engines": {
    "go": ">=1.24"
  }
}
