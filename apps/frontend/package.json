{
  "name": "frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:prod": "vue-tsc -b && vite build --mode production",
    "build:tauri": "vue-tsc -b && vite build --mode tauri",
    "build:mobile": "vue-tsc -b && vite build --mode mobile",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:win32": "tauri build --target i686-pc-windows-msvc",
    "tauri:build:win64": "pnpm run build:tauri && pnpm tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "vue-tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@vicons/ionicons5": "^0.13.0",
    "axios": "^1.13.2",
    "emoji-mart-vue-fast": "^15.0.5",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-icons-plus": "^0.1.8",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@tauri-apps/cli": "^2.9.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/vue": "^8.0.3",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vitest": "^2.1.8",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^3.1.4"
  }
}
