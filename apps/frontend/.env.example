# 环境配置示例
# 复制此文件为 .env 并根据需要修改

# API Base URL - 本地开发环境
VITE_API_BASE_URL=http://localhost:8080

# Storage Service Base URL - 存储服务（文件上传下载）
# 本地开发时指向存储服务，生产环境通过 nginx 代理可省略（默认与 API Base URL 相同）
# VITE_STORAGE_BASE_URL=http://localhost:8081

# 环境标识 (development | production)
VITE_APP_ENV=development

# 客户端类型 (web | tauri | mobile)
VITE_APP_CLIENT=web

# Bot 微服务 URL（可选，用于 XState 引擎调试）
# VITE_BOT_ENGINE_URL=http://localhost:3001

# 其他配置示例：
# API Base URL - 生产环境（网页端使用相对路径，通过 nginx 反向代理）
# VITE_API_BASE_URL=/

# API Base URL - Tauri 桌面端（连接到服务器）
# VITE_API_BASE_URL=https://your-server.com

# API Base URL - 移动端（连接到服务器）
# VITE_API_BASE_URL=https://your-server.com